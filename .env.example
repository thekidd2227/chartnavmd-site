# ARCG Systems — environment variables (example)
# Copy to .env.local (dev) or set on your build host (prod).

# ============================================================
# Chartnav — lead submission
# ------------------------------------------------------------
# PRODUCTION FLOW:
#   Chartnav form submit → Make.com webhook → Airtable downstream
#
# The Make scenario owns all downstream work: Airtable writes, email
# notifications, Slack pings, routing, enrichment, etc. This keeps every
# credential off the client bundle.
# ============================================================

# Production — Make.com custom webhook URL.
# Example shape:
#   https://hook.us2.make.com/abcd1234abcd1234abcd1234abcd1234
# When set, all form submissions POST JSON to this URL.
# Vite inlines this at BUILD TIME — any change requires `npm run build`.
# Full handoff: see docs/chartnav-integration.md or
# src/components/chartnav/MAKE_SCENARIO.md
VITE_CHARTNAV_LEAD_WEBHOOK=

# ------------------------------------------------------------
# SECONDARY / FALLBACK — direct Airtable from the client.
# DO NOT enable in production if the Make webhook is available.
# The PAT is shipped in the public JS bundle when this path runs.
# Only flip this to "true" when the Make path is not viable AND the
# business has accepted the PAT-exposure risk in writing.
# ------------------------------------------------------------
VITE_CHARTNAV_ALLOW_DIRECT_AIRTABLE=false

VITE_AIRTABLE_BASE_ID=
VITE_AIRTABLE_PAT=

# One combined table, or leave blank and use the per-form tables below.
VITE_AIRTABLE_TABLE_NAME=

# Per-form tables override VITE_AIRTABLE_TABLE_NAME when set.
VITE_AIRTABLE_DEMO_TABLE=
VITE_AIRTABLE_ASSESSMENT_TABLE=
